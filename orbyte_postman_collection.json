        {
          "name": "3.2 Editar Estado",
          "item": [
            {
              "name": "Editar — Registrado → En preparación (estado_id=2)",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Authorization", "value": "Token {{token_admin}}" },
                  { "key": "Content-Type",  "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"estado_id\": 2,\n  \"motivo\": \"Pedido verificado y confirmado, se inicia la preparación.\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{base_url}}/api/pedidos/{{pedido_id}}/editar/", "host": ["{{base_url}}"], "path": ["api","pedidos","{{pedido_id}}","editar",""] },
                "description": "Ejecutar en secuencia: este primero, luego Enviado, luego Completado.\nEl pedido_id=36 del seed está en estado Registrado."
              }
            },
            {
              "name": "Editar — En preparación → Enviado (estado_id=3)",
