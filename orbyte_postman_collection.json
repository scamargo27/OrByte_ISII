                "method": "PATCH",
                "header": [
                  { "key": "Authorization", "value": "Token {{token_admin}}" },
                  { "key": "Content-Type",  "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"estado_id\": 5,\n  \"motivo\": \"Cliente solicitó cancelación antes del inicio de preparación.\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{base_url}}/api/pedidos/{{pedido_id}}/editar/", "host": ["{{base_url}}"], "path": ["api","pedidos","{{pedido_id}}","editar",""] },
                "description": "Usar un pedido en estado Registrado. Al cancelar, el stock se devuelve automáticamente."
              }
            },
            {
              "name": "Editar — ERROR motivo muy corto → 400",
              "request": {
