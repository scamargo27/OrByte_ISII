# Desarrollo local: usa variables individuales de BD
DB_NAME=orbyte_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Producción (Render): define solo DATABASE_URL con la cadena de Neon
# DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Django
DEBUG=True
SECRET_KEY=cambia-esto-por-una-clave-segura-en-produccion
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — en producción reemplaza con tu dominio de Vercel
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000
